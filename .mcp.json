{
  "mcpServers": {
    "xcodebuild": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "xcodebuildmcp@latest"
      ],
      "env": {
        "XCODEBUILDMCP_WORKFLOWS": "project-discovery,simulator-management,simulator-control,ui-testing,builds,logging,doctor",
        "XCODEBUILDMCP_SENTRY_DISABLED": "1"
      }
    }
  }
}

{
  "sourceLanguage" : "ko",
  "strings" : {
    ":" : {
      "comment" : "A colon used in a time display.",
      "isCommentAutoGenerated" : true
    },
    "#%@" : {
      "comment" : "A chip displaying a memory tag. The text inside the chip is a hashtag prefixed by the memory tag name.",
      "isCommentAutoGenerated" : true
    },
    "%@" : {
      "comment" : "A label showing the number of memories in a cluster. The argument is the count of memories in the cluster.",
      "isCommentAutoGenerated" : true
    },
    "%@ · %@" : {
      "comment" : "A secondary label that provides options for how the event is tied to the current day or how a new event can be created.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@"
          }
        }
      }
    },
    "%@ · %@장" : {
      "comment" : "A line that shows the location of an event and the number of photos associated with it.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@장"
          }
        }
      }
    },
    "%@년" : {
      "comment" : "A year label in the month picker view. The text inside the quotation marks will be replaced with the actual year.",
      "isCommentAutoGenerated" : true
    },
    "%@번 방문 · %@장" : {
      "comment" : "A secondary line of text that shows the number of times a place was visited and the number of photos associated with it.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ko" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@번 방문 · %2$@장"
          }
        }
      }
    },
    "%@월" : {
      "comment" : "A button representing a month in a calendar view. The argument is the month number.",
      "isCommentAutoGenerated" : true
    },
    "%@장" : {
      "comment" : "A label displaying the number of photos associated with an event. The argument is the count of photos for the event.",
      "isCommentAutoGenerated" : true
    },
    "+%@" : {
      "comment" : "A small tag indicating that there are more people in a group than can be shown in a single row. The number inside the tag is the count of additional people.",
      "isCommentAutoGenerated" : true
    },
    "PHOTO %@" : {
      "comment" : "A label inside a photo tile, showing the index of the photo. The argument is the index of the photo.",
      "isCommentAutoGenerated" : true
    },

{
  "version": "2026-04-12",
  "project": "moment",
  "architecture": "planner-generator-evaluator",
  "providers": {
    "claude_api": {
      "transport": "cli",
      "auth": "claude-pro-login",
      "primary_use": [
        "product strategy",
        "market research",
        "planning",
        "task allocation",
        "architecture",
        "implementation",
        "code review",
        "UX audit",
        "accessibility check",
        "arbitration",
        "ops"
      ],
      "models": {
        "default": "claude-sonnet-4-6",
        "deep_review": "claude-opus-4-6",
        "ops": "claude-haiku-4-5-20251001"
      }
    },
    "codex_cli": {
      "transport": "cli",
      "auth": "chatgpt-pro-login",
      "primary_use": [
        "secondary implementation",
        "parallel worktree execution"
      ],
      "models": {
        "default": "gpt-5.4",
        "subagent": "gpt-5-codex-mini",
        "override_env": "FACTORY_CODEX_PRIMARY_MODEL"
      }
    }
  },
  "roles": [
    {
      "id": "platform_operator",
      "title": "Platform Operator",
      "team": "operations",
      "provider": "claude_api",
      "model": "claude-haiku-4-5-20251001",
      "ownership": [
        "context_harness/state.json",
        "context_harness/handoffs/",
        "context_harness/reports/"
      ],
      "responsibilities": [
        "Run the autonomous loop and keep lanes synchronized.",
        "Compact context, prepare merge packets, and protect token budgets.",
        "Maintain claude-progress.md with current state between sessions.",
        "Escalate when automation cannot safely resolve conflicts."
      ]
    },
    {
      "id": "product_lead",
      "title": "Product Lead (Planner)",
      "team": "planner",
      "provider": "claude_api",
      "model": "claude-opus-4-6",
      "ownership": [
        "context_harness/handoffs/product_brief.md",
        "reports/product_lead_product_research.md"
      ],
      "responsibilities": [
        "Analyze market demand, competitor landscape, and category risk for Korean social/event market.",
        "Validate product assumptions against Korean user behavior patterns.",
        "Produce concise product brief handoffs aligned with 모먼트 vision.",
        "Flag UX flows that could hurt conversion (especially RSVP funnel and 카카오톡 sharing)."
      ]
    },
    {
      "id": "delivery_lead",
      "title": "Delivery Lead (Planner)",
      "team": "planner",
      "provider": "claude_api",
      "model": "claude-sonnet-4-6",
      "ownership": [
        "context_harness/handoffs/fork_decision.json",
        "reports/delivery_lead_planning.md"
      ],
      "responsibilities": [
        "Convert product brief into sprint milestones, task graph, and ownership.",
        "Define web architecture decisions (Next.js routes, Supabase schema, Edge Functions).",
        "Negotiate sprint contracts with testable acceptance criteria.",
        "Decide whether subagent forks are justified.",
        "Keep token budget under control."
      ]
    },
    {
      "id": "web_builder",
      "title": "Web Builder (Generator)",
      "team": "generator",
      "provider": "claude_api",
      "model": "claude-opus-4-6",
      "ownership": [
        "workspace/",
        ".worktrees/web_builder"
      ],
      "responsibilities": [
        "Implement Next.js pages, components, and API routes.",
        "Build Supabase schema, RLS policies, and Edge Functions.",
        "Create PWA configuration and service worker.",
        "Implement 카카오 OAuth and OG meta generation.",
        "Stay inside sprint contract scope.",
        "Write TypeScript strict-mode code with proper type safety."
      ]
    },
    {
      "id": "reviewer",
      "title": "Reviewer (Evaluator)",
      "team": "evaluator",
      "provider": "claude_api",
      "model": "claude-opus-4-6",
      "ownership": [
        "reports/reviewer_code_review.md",
        "reports/reviewer_ux_audit.md"
      ],
      "responsibilities": [
        "Review code for correctness, security (RLS, XSS, injection), and performance.",
        "Audit UX against acceptance criteria and design direction.",
        "Check accessibility (touch targets, contrast, font sizes).",
        "Verify 카카오톡 OG rendering and PWA compliance.",
        "Assume the implementation is wrong until proven otherwise.",
        "Return file-specific, actionable feedback with line numbers.",
        "Block release when evaluation evidence is insufficient."
      ]
    }
  ],
  "routing": [
    {
      "task": "product_research",
      "primary_role": "product_lead",
      "fallback_roles": ["delivery_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "market_research",
      "primary_role": "product_lead",
      "fallback_roles": ["delivery_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "planning",
      "primary_role": "delivery_lead",
      "fallback_roles": ["product_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "task_allocation",
      "primary_role": "delivery_lead",
      "fallback_roles": ["product_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "prd_generation",
      "primary_role": "delivery_lead",
      "fallback_roles": ["product_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "architecture",
      "primary_role": "delivery_lead",
      "fallback_roles": ["product_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "web_implementation",
      "primary_role": "web_builder",
      "fallback_roles": ["delivery_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "frontend_coding",
      "primary_role": "web_builder",
      "fallback_roles": ["delivery_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "backend_coding",
      "primary_role": "web_builder",
      "fallback_roles": ["delivery_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "code_review",
      "primary_role": "reviewer",
      "fallback_roles": ["delivery_lead"],
      "evaluation_roles": ["product_lead"]
    },
    {
      "task": "ux_audit",
      "primary_role": "reviewer",
      "fallback_roles": ["product_lead"],
      "evaluation_roles": ["delivery_lead"]
    },
    {
      "task": "bug_fix",
      "primary_role": "web_builder",
      "fallback_roles": ["delivery_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "sprint_eval",
      "primary_role": "reviewer",
      "fallback_roles": ["product_lead"],
      "evaluation_roles": ["delivery_lead"]
    },
    {
      "task": "documentation",
      "primary_role": "delivery_lead",
      "fallback_roles": ["product_lead"],
      "evaluation_roles": ["reviewer"]
    },
    {
      "task": "arbitration",
      "primary_role": "delivery_lead",
      "fallback_roles": ["reviewer"],
      "evaluation_roles": ["product_lead"]
    }
  ],
  "fork_policy": {
    "spawn_when": [
      "the task has bounded acceptance criteria",
      "the write scope is disjoint (e.g., frontend vs backend vs schema)",
      "the parent agent can continue independently",
      "the fork returns a concrete verification artifact"
    ],
    "avoid_when": [
      "the parent is blocked on the answer",
      "ownership overlaps another active agent",
      "the request is still ambiguous"
    ],
    "parallel_limit": 3
  }
}

{
  "dataset_id": "cifar10",
  "dataset_family": "torchvision_cifar",
  "input_shape": [3, 32, 32],
  "num_classes": 10,
  "download_source": "torchvision.datasets.CIFAR10",
  "splits": {
    "train": 45000,
    "validation": 5000,
    "test": 10000
  },
  "normalization": {
    "mean": [0.4914, 0.4822, 0.4465],
    "std": [0.2470, 0.2435, 0.2616]
  },
  "benchmark_targets": {
    "primary_metric": "top1_accuracy",
    "expected_baseline_accuracy": 0.94,
    "stretch_accuracy": 0.99
  },
  "notes": [
    "Validation split must use a fixed seed before the first run.",
    "Evaluator only touches the test split during final evaluation."
  ]
}

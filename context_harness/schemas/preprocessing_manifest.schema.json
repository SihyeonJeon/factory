{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context_harness/schemas/preprocessing_manifest.schema.json",
  "title": "Preprocessing Manifest",
  "type": "object",
  "required": [
    "preprocessing_id",
    "domain",
    "sample_rate",
    "clip_seconds",
    "feature_type",
    "feature_shape"
  ],
  "properties": {
    "preprocessing_id": { "type": "string" },
    "domain": { "type": "string" },
    "sample_rate": { "type": "integer", "minimum": 1 },
    "clip_seconds": { "type": "number", "minimum": 0.1 },
    "feature_type": { "type": "string" },
    "feature_shape": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 2,
      "maxItems": 3
    },
    "logmel": {
      "type": "object",
      "properties": {
        "n_mels": { "type": "integer", "minimum": 1 },
        "n_fft": { "type": "integer", "minimum": 1 },
        "hop_length": { "type": "integer", "minimum": 1 },
        "fmin": { "type": "integer", "minimum": 0 },
        "fmax": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "chunking": {
      "type": "object",
      "properties": {
        "window_seconds": { "type": "number", "minimum": 0.1 },
        "stride_seconds": { "type": "number", "minimum": 0.1 },
        "aggregation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "augmentations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

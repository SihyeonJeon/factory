{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "context_harness/schemas/eval_manifest.schema.json",
  "title": "Evaluation Manifest",
  "type": "object",
  "required": [
    "eval_id",
    "run_id",
    "metrics"
  ],
  "properties": {
    "eval_id": { "type": "string" },
    "run_id": { "type": "string" },
    "checkpoint_policy": { "type": "string" },
    "baseline_run_id": { "type": "string" },
    "ablation_axis": { "type": "string" },
    "ensemble_id": { "type": "string" },
    "pseudo_label_round": { "type": "integer", "minimum": 0 },
    "inference_budget": {
      "type": "object",
      "properties": {
        "max_latency_ms": { "type": "number" },
        "max_peak_memory_mb": { "type": "number" },
        "must_fit_kaggle_notebook": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "external_comparison_required": { "type": "boolean" },
    "comparison_targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}

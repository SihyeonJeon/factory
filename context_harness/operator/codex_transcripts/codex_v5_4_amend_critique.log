   126	def parse_simple_frontmatter(block: str) -> dict:
   127	    """Minimal YAML-subset parser for meeting frontmatter.
   128	    Supports: `key: value`, `key: [a, b, c]`. No multiline or anchors.
   129	    """
   130	    out: dict = {}
   131	    for raw in block.splitlines():
   132	        line = raw.rstrip()
   133	        if not line or line.lstrip().startswith("#"):
   134	            continue
   135	        if ":" not in line:
   136	            continue
   137	        key, _, value = line.partition(":")
   138	        key = key.strip()
   139	        value = value.strip()
   140	        if value.startswith(("\"", "'")) and value.endswith(value[0]):
   141	            value = value[1:-1]
   142	        if value.startswith("[") and value.endswith("]"):
   143	            inner = value[1:-1].strip()
   144	            items = [x.strip().strip("\"'") for x in inner.split(",")] if inner else []
   145	            out[key] = items
   146	        else:
   147	            out[key] = value
   148	    return out

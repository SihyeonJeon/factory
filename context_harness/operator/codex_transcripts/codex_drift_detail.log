   383	def main(argv: list[str]) -> int:
   384	    if len(argv) < 2:
   385	        print(__doc__)
   386	        return 2
   387	    cmd = argv[1]
   388	    if cmd == "lint":
   389	        report = cmd_lint()
   390	    elif cmd == "audit-operator-layer":
   391	        report = cmd_audit_operator_layer()
   392	    elif cmd == "lock" and len(argv) >= 3:
   393	        report = cmd_lock(argv[2])
   394	    elif cmd == "gates" and len(argv) >= 3:
   395	        report = cmd_gates(argv[2])
   396	    else:
   397	        print(__doc__)
   398	        return 2
   399	    print(report.render())
   400	    return report.exit_code()

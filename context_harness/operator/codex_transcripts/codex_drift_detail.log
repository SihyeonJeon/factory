   199	def check_meeting_frontmatter(cfg: dict, report: CheckReport) -> None:
   200	    meetings_dir = OPERATOR_DIR / "meetings"
   201	    if not meetings_dir.exists():
   202	        return
   203	    required = cfg.get("meeting_required_frontmatter", [])
   204	    allowed = cfg.get("meeting_frontmatter_allowed", {})
   205	    decided_sections = cfg.get("meeting_required_sections", {}).get("decided", [])
   206	    challenge = cfg.get("challenge_section", {})
   207	    factual_stages = set(challenge.get("factual_stages", []))
   208	    factual_phrase = challenge.get("factual_required_phrase", "")
   209	    decision_keywords = challenge.get("decision_required_keywords", [])
   210	
   211	    for mp in sorted(meetings_dir.glob("*.md")):
   212	        if mp.name.startswith("_"):
   213	            continue  # templates
   214	        text = mp.read_text()
   215	        # Extract frontmatter
   216	        fm_match = re.match(r"^---\n(.*?)\n---\n", text, re.DOTALL)
   217	        if not fm_match:
   218	            report.blocker(f"meeting missing frontmatter: {mp.name}")
   219	            continue
   220	        try:
   221	            fm = parse_simple_frontmatter(fm_match.group(1))
   222	        except Exception as e:
   223	            report.blocker(f"meeting frontmatter invalid ({mp.name}): {e}")
   224	            continue
   225	        # Required keys
   226	        for k in required:
   227	            if k not in fm:
   228	                report.blocker(f"meeting {mp.name} missing frontmatter key: {k}")
   229	        # Allowed values
   230	        for k, allowed_values in allowed.items():
   231	            v = fm.get(k)
   232	            if v is not None and v not in allowed_values:
   233	                report.blocker(f"meeting {mp.name} frontmatter {k}={v} not in allowed values")
   234	        # Section + Challenge rules
   235	        status = fm.get("status")
   236	        stage = fm.get("stage")
   237	        if status == "decided":
   238	            for sec in decided_sections:
   239	                if sec not in text:
   240	                    report.blocker(f"meeting {mp.name} status=decided missing required section: {sec}")
   241	            # Challenge Section content
   242	            cs_match = re.search(r"## Challenge Section\s*(.*?)(?=\n## |\Z)", text, re.DOTALL)
   243	            cs_body = cs_match.group(1) if cs_match else ""
   244	            if stage in factual_stages:
   245	                if factual_phrase not in cs_body:
   246	                    report.blocker(f"meeting {mp.name} (factual) Challenge missing required phrase")
   247	            else:
   248	                if not any(kw.lower() in cs_body.lower() for kw in decision_keywords):
   249	                    report.blocker(f"meeting {mp.name} Challenge Section lacks any of: {decision_keywords}")
   250	        if stage and allowed.get("stage") and stage not in allowed["stage"]:
   251	            # Already caught above, but double-safety
   252	            pass
   253	

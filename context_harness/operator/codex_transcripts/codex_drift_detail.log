   305	def cmd_lock(round_id: str) -> CheckReport:
   306	    cfg = load_lint_config()
   307	    report = CheckReport()
   308	    round_dir = CONTRACTS_DIR / round_id
   309	    if not round_dir.exists():
   310	        report.blocker(f"contract directory missing: {round_dir}")
   311	        return report
   312	    required = ["spec.md", "file_whitelist.txt", "convention_version.txt", "lint_config.txt", "acceptance.md", "eval_protocol.md"]
   313	    hashes: dict[str, str] = {}
   314	    for f in required:
   315	        p = round_dir / f
   316	        if not p.exists():
   317	            report.blocker(f"contract file missing: {round_id}/{f}")
   318	            continue
   319	        hashes[f] = sha256_file(p)
   320	        report.ok(f"hashed {round_id}/{f}")
   321	    if report.blockers:
   322	        return report
   323	    LOCKS_DIR.mkdir(parents=True, exist_ok=True)
   324	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   325	    if lock_path.exists():
   326	        report.blocker(f"lock already exists: {lock_path}")
   327	        return report
   328	    lock = {
   329	        "round_id": round_id,
   330	        "schema_version": 1,
   331	        "started_at": datetime.now(timezone.utc).isoformat(),
   332	        "status": "active",
   333	        "operators": {
   334	            "claude_code": {"session": "this-session", "role_default": "implementer"},
   335	            "codex": {"session": "", "role_default": "designer_reviewer"},
   336	        },
   337	        "hashes": hashes,
   338	        "amendments": [],
   339	        "stages_completed": [],
   340	        "closed_at": None,
   341	    }
   342	    lock_path.write_text(json.dumps(lock, indent=2) + "\n")
   343	    report.ok(f"lock created: {lock_path}")
   344	    return report
   345	
   346	
   347	def cmd_gates(round_id: str) -> CheckReport:
   348	    cfg = load_lint_config()
   349	    report = CheckReport()
   350	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   351	    if not lock_path.exists():
   352	        report.blocker(f"lock missing: {lock_path}")
   353	        return report
   354	    try:
   355	        lock = json.loads(lock_path.read_text())
   356	    except json.JSONDecodeError as e:
   357	        report.blocker(f"lock JSON invalid: {e}")
   358	        return report
   359	    # Verify contract file hashes match
   360	    round_dir = CONTRACTS_DIR / round_id
   361	    for fname, expected in lock.get("hashes", {}).items():
   362	        p = round_dir / fname
   363	        if not p.exists():
   364	            report.blocker(f"contract file missing (hashed at lock): {fname}")
   365	            continue
   366	        actual = sha256_file(p)
   367	        if actual != expected:
   368	            report.blocker(f"contract file MUTATED after lock: {fname} expected {expected[:20]} got {actual[:20]}")
   369	        else:
   370	            report.ok(f"contract file immutable: {fname}")
   371	    # Lint + operator-layer audit
   372	    lint_report = cmd_lint()
   373	    audit_report = cmd_audit_operator_layer()
   374	    report.blockers.extend(lint_report.blockers)
   375	    report.blockers.extend(audit_report.blockers)
   376	    report.advisories.extend(lint_report.advisories)
   377	    report.advisories.extend(audit_report.advisories)
   378	    report.passes.extend(lint_report.passes)
   379	    report.passes.extend(audit_report.passes)
   380	    return report
   381	

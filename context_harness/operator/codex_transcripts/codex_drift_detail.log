    90	def parse_simple_frontmatter(block: str) -> dict:
    91	    """Minimal YAML-subset parser for meeting frontmatter.
    92	    Supports: `key: value`, `key: [a, b, c]`, `key: value_with_colons_after_first`.
    93	    Strips inline values; no multiline scalars, no anchors, no nested maps.
    94	    """
    95	    out: dict = {}
    96	    for raw in block.splitlines():
    97	        line = raw.rstrip()
    98	        if not line or line.lstrip().startswith("#"):
    99	            continue
   100	        if ":" not in line:
   101	            continue
   102	        key, _, value = line.partition(":")
   103	        key = key.strip()
   104	        value = value.strip()
   105	        # Strip surrounding quotes if any
   106	        if value.startswith(("\"", "'")) and value.endswith(value[0]):
   107	            value = value[1:-1]
   108	        # Inline list
   109	        if value.startswith("[") and value.endswith("]"):
   110	            inner = value[1:-1].strip()
   111	            items = [x.strip().strip("\"'") for x in inner.split(",")] if inner else []
   112	            out[key] = items
   113	        else:
   114	            out[key] = value
   115	    return out

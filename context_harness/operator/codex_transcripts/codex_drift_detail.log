   255	def audit_operator_layer(report: CheckReport, cfg: dict) -> None:
   256	    # Docs existence
   257	    for expected in [
   258	        "OPERATOR.md",
   259	        "FILE_INDEX.md",
   260	        "STAGE_CONTRACT.md",
   261	        "MEETING_PROTOCOL.md",
   262	        "REGULATION.md",
   263	        "PROCESS_AUDIT_CHECKLIST.md",
   264	        "CHANGELOG.md",
   265	    ]:
   266	        p = OPERATOR_DIR / expected
   267	        if not p.exists():
   268	            report.blocker(f"operator doc missing: {expected}")
   269	        else:
   270	            report.ok(f"operator doc present: {expected}")
   271	    # Stage name consistency across STAGE_CONTRACT and MEETING_PROTOCOL
   272	    sc = (OPERATOR_DIR / "STAGE_CONTRACT.md").read_text() if (OPERATOR_DIR / "STAGE_CONTRACT.md").exists() else ""
   273	    mp = (OPERATOR_DIR / "MEETING_PROTOCOL.md").read_text() if (OPERATOR_DIR / "MEETING_PROTOCOL.md").exists() else ""
   274	    allowed_stages = cfg.get("meeting_frontmatter_allowed", {}).get("stage", [])
   275	    for st in allowed_stages:
   276	        if st not in mp:
   277	            report.blocker(f"stage '{st}' listed in lint_config but not in MEETING_PROTOCOL")
   278	    # Precedence order consistency
   279	    precedence = cfg.get("precedence", [])
   280	    reg = (OPERATOR_DIR / "REGULATION.md").read_text() if (OPERATOR_DIR / "REGULATION.md").exists() else ""
   281	    if "Precedence Ladder" not in reg:
   282	        report.blocker("REGULATION.md missing Precedence Ladder section")
   283	    for doc in precedence:
   284	        if isinstance(doc, str) and doc.startswith("context_harness/operator/") and doc not in reg:
   285	            report.advisory(f"precedence entry '{doc}' not textually present in REGULATION.md")

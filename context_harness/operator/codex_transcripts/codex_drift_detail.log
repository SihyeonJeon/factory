     1	#!/usr/bin/env python3
     2	"""
     3	Operator-round checker for Harness v5.
     4	
     5	Commands:
     6	  lock <round_id>            Create operator/locks/<round_id>.lock from contract files
     7	  gates <round_id>           Run Gate 5 process-integrity checks for a round
     8	  audit-operator-layer       Run operator-layer drift audit (standalone)
     9	  lint                       Lint operator docs against lint_config.yaml
    10	
    11	Exits 0 on pass, non-zero on any blocker.
    12	"""
    13	
    14	from __future__ import annotations
    15	
    16	import hashlib
    17	import json
    18	import re
    19	import sys
    20	from dataclasses import dataclass, field
    21	from datetime import datetime, timezone
    22	from pathlib import Path
    23	from typing import Iterable
    24	
    25	try:
    26	    import tomllib  # Python 3.11+
    27	except ImportError:  # Python < 3.11
    28	    try:
    29	        import tomli as tomllib  # type: ignore
    30	    except ImportError:
    31	        sys.stderr.write(
    32	            "tomllib (Python 3.11+) or tomli package required for TOML parsing.\n"
    33	        )
    34	        sys.exit(2)
    35	
    36	
    37	REPO = Path(__file__).resolve().parent.parent
    38	OPERATOR_DIR = REPO / "context_harness" / "operator"
    39	LINT_CONFIG = OPERATOR_DIR / "lint_config.toml"
    40	LOCKS_DIR = OPERATOR_DIR / "locks"
    41	CONTRACTS_DIR = OPERATOR_DIR / "contracts"
    42	FILE_INDEX = OPERATOR_DIR / "FILE_INDEX.md"
    43	
    44	
    45	@dataclass
    46	class CheckReport:
    47	    blockers: list[str] = field(default_factory=list)
    48	    advisories: list[str] = field(default_factory=list)
    49	    passes: list[str] = field(default_factory=list)
    50	
    51	    def blocker(self, msg: str) -> None:
    52	        self.blockers.append(msg)
    53	
    54	    def advisory(self, msg: str) -> None:
    55	        self.advisories.append(msg)
    56	
    57	    def ok(self, msg: str) -> None:
    58	        self.passes.append(msg)
    59	
    60	    def exit_code(self) -> int:
    61	        return 1 if self.blockers else 0
    62	
    63	    def render(self) -> str:
    64	        lines = []
    65	        for msg in self.passes:
    66	            lines.append(f"  ok       {msg}")
    67	        for msg in self.advisories:
    68	            lines.append(f"  advisory {msg}")
    69	        for msg in self.blockers:

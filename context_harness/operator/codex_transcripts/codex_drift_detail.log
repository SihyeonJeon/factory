   145	def check_loader_pointers(cfg: dict, report: CheckReport) -> None:
   146	    for entry in cfg.get("loader_pointers", []):
   147	        f = REPO / entry["file"]
   148	        must = entry["must_reference"]
   149	        if not f.exists():
   150	            report.blocker(f"loader missing: {entry['file']}")
   151	            continue
   152	        if must not in f.read_text():
   153	            report.blocker(f"loader {entry['file']} does not reference {must}")
   154	        else:
   155	            report.ok(f"loader references target: {entry['file']} → {must}")
   156	
   157	
   158	def check_file_index_coverage(cfg: dict, report: CheckReport) -> None:
   159	    coverage = cfg.get("file_index_coverage", {})
   160	    if not coverage:
   161	        return
   162	    target = REPO / coverage["target"]
   163	    if not target.exists():
   164	        report.blocker(f"FILE_INDEX target missing: {coverage['target']}")
   165	        return
   166	    index_text = target.read_text()
   167	    exempt_globs = coverage.get("exempt", [])
   168	    candidates: list[Path] = []
   169	    for pattern in coverage.get("required_scan_globs", []):
   170	        candidates.extend(REPO.glob(pattern))
   171	
   172	    def is_exempt(p: Path) -> bool:
   173	        rel = p.relative_to(REPO).as_posix()
   174	        for g in exempt_globs:
   175	            # Very simple glob match: accept prefix/** or direct equality.
   176	            if g.endswith("/**"):
   177	                if rel.startswith(g[:-3]):
   178	                    return True
   179	            elif rel == g:
   180	                return True
   181	        return False
   182	
   183	    missing: list[str] = []
   184	    for p in sorted(set(candidates)):
   185	        if is_exempt(p):
   186	            continue
   187	        rel = p.relative_to(REPO).as_posix()
   188	        # Match by full rel path OR by the filename at end — more forgiving than strict path match.
   189	        if rel in index_text or p.name in index_text:
   190	            continue
   191	        missing.append(rel)
   192	    if missing:
   193	        for m in missing:
   194	            report.blocker(f"FILE_INDEX missing entry for: {m}")
   195	    else:
   196	        report.ok("FILE_INDEX coverage complete")
   197	

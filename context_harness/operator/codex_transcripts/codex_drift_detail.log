   124	def check_line_caps(cfg: dict, report: CheckReport) -> None:
   125	    caps = cfg.get("line_caps", {})
   126	    warnings = cfg.get("line_warnings", {})
   127	    for rel, cap in caps.items():
   128	        p = REPO / rel
   129	        if not p.exists():
   130	            report.blocker(f"line-cap target missing: {rel}")
   131	            continue
   132	        n = line_count(p)
   133	        if n > cap:
   134	            report.blocker(f"line cap exceeded: {rel} = {n} lines (cap {cap})")
   135	        else:
   136	            report.ok(f"line cap: {rel} = {n}/{cap}")
   137	    for rel, warn in warnings.items():
   138	        p = REPO / rel
   139	        if p.exists():
   140	            n = line_count(p)
   141	            if n > warn:
   142	                report.advisory(f"line warning: {rel} = {n} (warn ≥ {warn})")
   143	

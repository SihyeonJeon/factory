struct SampleMemoryPin: Identifiable, Hashable {
    let id: UUID
    let title: String
    let shortLabel: String
    let coordinate: CLLocationCoordinate2D
    let symbol: String
    let color: Color

    static func == (lhs: SampleMemoryPin, rhs: SampleMemoryPin) -> Bool {
        lhs.id == rhs.id
    }

    func hash(into hasher: inout Hasher) {
        hasher.combine(id)
    }


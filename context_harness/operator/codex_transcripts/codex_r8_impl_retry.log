+    func test_grid_builds_for_sample_weeks() {
+        let store = MemoryCalendarStore(today: Date(timeIntervalSince1970: 1_775_232_000))
+        let harness = MonthGridHarness(weeks: store.weeks())
+        XCTAssertNotNil(harness.body)

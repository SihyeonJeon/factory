                    .font(UnfadingTheme.Font.subheadline())
                    .foregroundStyle(UnfadingTheme.Color.textSecondary)
                    .fixedSize(horizontal: false, vertical: true)

                tagSection
            }
            .padding(UnfadingTheme.Spacing.xl)

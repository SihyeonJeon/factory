+                                startPoint: .topLeading,
+                                endPoint: .bottomTrailing
+                            )
+                        )
+                        .frame(width: 220, height: 165)
+                        .overlay {
+                            Image(systemName: symbol)
+                                .font(.largeTitle.weight(.semibold))
+                                .foregroundStyle(UnfadingTheme.Color.textOnPrimary)
+                        }

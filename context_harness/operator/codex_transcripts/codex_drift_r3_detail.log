   469	def cmd_lock(round_id: str) -> CheckReport:
   470	    report = CheckReport()
   471	    round_dir = CONTRACTS_DIR / round_id
   472	    if not round_dir.exists():
   473	        report.blocker(f"contract directory missing: {round_dir}")
   474	        return report
   475	    hashes: dict[str, str] = {}
   476	    for f in REQUIRED_CONTRACT_FILES:
   477	        p = round_dir / f
   478	        if not p.exists():
   479	            report.blocker(f"contract file missing: {round_id}/{f}")
   480	            continue
   481	        hashes[f] = sha256_file(p)
   482	        report.ok(f"hashed {round_id}/{f}")
   483	    if report.blockers:
   484	        return report
   485	    LOCKS_DIR.mkdir(parents=True, exist_ok=True)
   486	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   487	    if lock_path.exists():
   488	        report.blocker(f"lock already exists: {lock_path}")
   489	        return report
   490	    # base_commit for commit traceability (item 11)
   491	    try:
   492	        base_commit = subprocess.check_output(
   493	            ["git", "rev-parse", "HEAD"], cwd=REPO, text=True
   494	        ).strip()
   495	    except Exception:
   496	        base_commit = None
   497	    lock = {
   498	        "round_id": round_id,
   499	        "schema_version": 1,
   500	        "started_at": datetime.now(timezone.utc).isoformat(),
   501	        "status": "active",
   502	        "operators": {
   503	            "claude_code": {"session": "this-session", "role_default": "implementer"},
   504	            "codex": {"session": "", "role_default": "designer_reviewer"},
   505	        },
   506	        "base_commit": base_commit,
   507	        "hashes": hashes,
   508	        "amendments": [],
   509	        "stages_completed": [],
   510	        "closed_at": None,
   511	    }
   512	    lock_path.write_text(json.dumps(lock, indent=2) + "\n")
   513	    report.ok(f"lock created: {lock_path} (base_commit={base_commit or 'unknown'})")
   514	    report.ok("ready")
   515	    return report

   544	
   545	def check_commit_traceability(lock: dict, report: CheckReport) -> None:
   546	    """Item 11 (v5.1) + v5.2 fixes: commits AND uncommitted changes since lock base_commit
   547	    must touch only whitelisted files. Uses proper glob matching."""
   548	    base = lock.get("base_commit")
   549	    round_dir = CONTRACTS_DIR / lock["round_id"]
   550	    wl_path = round_dir / "file_whitelist.txt"
   551	    if not base:
   552	        report.advisory("lock has no base_commit — commit traceability cannot be verified (legacy lock)")
   553	        return
   554	    if not wl_path.exists():
   555	        report.blocker("file_whitelist.txt missing — cannot verify commit traceability")
   556	        return
   557	    # Effective whitelist = base + amendments (additive/subtractive via + / -)
   558	    whitelist: set[str] = set()
   559	    for ln in wl_path.read_text().splitlines():
   560	        ln = ln.strip()
   561	        if ln and not ln.startswith("#"):
   562	            whitelist.add(ln)
   563	    for amend in lock.get("amendments", []):
   564	        fname = amend.get("file", "")
   565	        apath = round_dir / fname
   566	        if apath.exists() and fname.startswith("file_whitelist.amendment."):
   567	            for ln in apath.read_text().splitlines():
   568	                ln = ln.strip()
   569	                if ln.startswith("+"):
   570	                    whitelist.add(ln[1:].strip())
   571	                elif ln.startswith("-"):
   572	                    whitelist.discard(ln[1:].strip())
   573	    # Collect touched files: committed + uncommitted + staged
   574	    touched: set[str] = set()
   575	    try:
   576	        committed = subprocess.check_output(
   577	            ["git", "diff", "--name-only", f"{base}..HEAD"], cwd=REPO, text=True
   578	        ).strip().splitlines()
   579	        touched.update(f for f in committed if f)
   580	    except Exception as e:
   581	        report.blocker(f"git diff base..HEAD failed: {e}")
   582	        return
   583	    try:
   584	        # Uncommitted (working tree + staged)
   585	        dirty = subprocess.check_output(
   586	            ["git", "status", "--porcelain"], cwd=REPO, text=True
   587	        ).strip().splitlines()
   588	        for ln in dirty:
   589	            # porcelain format: XY <filename>[ -> <renamed>]
   590	            if len(ln) < 4:
   591	                continue
   592	            fn = ln[3:].split(" -> ")[-1].strip()
   593	            if fn:
   594	                touched.add(fn)
   595	    except Exception as e:
   596	        report.advisory(f"git status --porcelain unavailable: {e}")
   597	    out_of_scope = [f for f in sorted(touched) if not _matches_any(f, whitelist)]
   598	    if out_of_scope:
   599	        for f in out_of_scope:
   600	            report.blocker(f"commit/working-tree touches out-of-whitelist path: {f}")
   601	    else:
   602	        report.ok(f"commit traceability ok ({len(touched)} file(s) vs whitelist)")
   603	

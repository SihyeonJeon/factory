   605	def check_live_pointer_hashes(lock: dict, report: CheckReport) -> None:
   606	    """Item 5 (v5.1) + v5.2: pointer files must be `<path>\\n<sha>` format. Malformed = BLOCKER."""
   607	    round_dir = CONTRACTS_DIR / lock["round_id"]
   608	    for name in ("lint_config.txt", "convention_version.txt"):
   609	        p = round_dir / name
   610	        entry = read_pointer_file(p)
   611	        if entry is None:
   612	            report.blocker(f"{name} malformed (expected `<path>\\n<sha256:...>` 2-line format)")
   613	            continue
   614	        target_rel, expected = entry
   615	        if not expected.startswith("sha256:"):
   616	            report.blocker(f"{name} second line must start with `sha256:` — got `{expected[:20]}...`")
   617	            continue
   618	        target = REPO / target_rel
   619	        if not target.exists():
   620	            report.blocker(f"{name} points at missing target: {target_rel}")
   621	            continue
   622	        actual = sha256_file(target)
   623	        if actual != expected:
   624	            report.blocker(f"{name} target {target_rel} live SHA differs from locked SHA")
   625	        else:
   626	            report.ok(f"{name} live hash matches locked target")

   688	def load_gate_evidence(round_id: str, report: CheckReport) -> dict | None:
   689	    """v5.2: `close` requires contracts/<round>/gate_evidence.json with all 4 gates pass."""
   690	    p = CONTRACTS_DIR / round_id / "gate_evidence.json"
   691	    if not p.exists():
   692	        report.blocker(f"gate_evidence.json missing at {p}")
   693	        return None
   694	    try:
   695	        ev = json.loads(p.read_text())
   696	    except json.JSONDecodeError as e:
   697	        report.blocker(f"gate_evidence.json invalid JSON: {e}")
   698	        return None
   699	    for g in ("gate1", "gate2", "gate3", "gate4"):
   700	        g_ev = ev.get(g)
   701	        if not isinstance(g_ev, dict) or g_ev.get("status") != "pass":
   702	            report.blocker(f"gate_evidence.{g} is not `pass`: {g_ev}")
   703	        else:
   704	            report.ok(f"gate_evidence.{g} = pass")
   705	    return ev

   629	def validate_amendments(lock: dict, report: CheckReport) -> None:
   630	    """v5.2: every amendment in lock.amendments[] must be a valid artifact.
   631	    Check: file exists, sha matches lock entry, frontmatter (target/supersedes/meeting) present,
   632	    meeting exists with status: decided, target ∈ base contract files.
   633	    """
   634	    round_dir = CONTRACTS_DIR / lock["round_id"]
   635	    base_files = set(REQUIRED_CONTRACT_FILES)
   636	    for amend in lock.get("amendments", []):
   637	        fname = amend.get("file")
   638	        if not fname:
   639	            report.blocker(f"amendment entry missing `file`: {amend}")
   640	            continue
   641	        apath = round_dir / fname
   642	        if not apath.exists():
   643	            report.blocker(f"amendment file missing: {fname}")
   644	            continue
   645	        # Hash
   646	        expected = amend.get("sha256")
   647	        if expected and sha256_file(apath) != expected:
   648	            report.blocker(f"amendment {fname} SHA differs from lock")
   649	        # Frontmatter (for .md amendments; .txt uses the lock entry for metadata)
   650	        text = apath.read_text()
   651	        if fname.endswith(".md"):
   652	            fm_match = re.match(r"^---\n(.*?)\n---\n", text, re.DOTALL)
   653	            if not fm_match:
   654	                report.blocker(f"amendment {fname} missing frontmatter")
   655	                continue
   656	            fm = parse_simple_frontmatter(fm_match.group(1))
   657	            for k in ("target", "supersedes", "meeting"):
   658	                if k not in fm:
   659	                    report.blocker(f"amendment {fname} frontmatter missing `{k}`")
   660	            target = fm.get("target")
   661	            if target and target not in base_files:
   662	                report.blocker(f"amendment {fname} target `{target}` not a base contract file")
   663	            meeting_path = fm.get("meeting")
   664	            if meeting_path:
   665	                mp = REPO / meeting_path if meeting_path.startswith("context_harness/") else OPERATOR_DIR / "meetings" / Path(meeting_path).name
   666	                if not mp.exists():
   667	                    report.blocker(f"amendment {fname} meeting not found: {meeting_path}")
   668	                else:
   669	                    mtext = mp.read_text()
   670	                    fm_match = re.match(r"^---\n(.*?)\n---\n", mtext, re.DOTALL)
   671	                    if fm_match:
   672	                        mfm = parse_simple_frontmatter(fm_match.group(1))
   673	                        if mfm.get("status") != "decided":
   674	                            report.blocker(f"amendment {fname} references non-decided meeting: {meeting_path}")
   675	        report.ok(f"amendment valid: {fname}")

   708	def cmd_gates(round_id: str) -> CheckReport:
   709	    cfg = load_lint_config()
   710	    report = CheckReport()
   711	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   712	    if not lock_path.exists():
   713	        report.blocker(f"lock missing: {lock_path}")
   714	        return report
   715	    try:
   716	        lock = json.loads(lock_path.read_text())
   717	    except json.JSONDecodeError as e:
   718	        report.blocker(f"lock JSON invalid: {e}")
   719	        return report
   720	    round_dir = CONTRACTS_DIR / round_id
   721	    # Contract immutability
   722	    for fname, expected in lock.get("hashes", {}).items():
   723	        p = round_dir / fname
   724	        if not p.exists():
   725	            report.blocker(f"contract file missing (hashed at lock): {fname}")
   726	            continue
   727	        actual = sha256_file(p)
   728	        if actual != expected:
   729	            report.blocker(f"contract file MUTATED after lock: {fname} expected {expected[:20]} got {actual[:20]}")
   730	        else:
   731	            report.ok(f"contract file immutable: {fname}")
   732	    # Live pointer hashes (lint/convention) — v5.2 malformed = blocker
   733	    check_live_pointer_hashes(lock, report)
   734	    # v5.2: amendment validation
   735	    validate_amendments(lock, report)
   736	    # v5.2: stages_completed structural check
   737	    validate_stages_completed(lock, cfg, report)
   738	    # Commit traceability (v5.2: includes uncommitted)
   739	    check_commit_traceability(lock, report)
   740	    # Lint + audit
   741	    lint_report = cmd_lint()
   742	    audit_report = cmd_audit_operator_layer()
   743	    report.merge(lint_report)
   744	    report.merge(audit_report)
   745	    return report
   746	
   747	
   748	def cmd_close(round_id: str) -> CheckReport:
   749	    """v5.2: close requires Gate 5 pass AND contracts/<round>/gate_evidence.json with gate1..gate4 all pass."""
   750	    report = cmd_gates(round_id)
   751	    # v5.2: require external gate_evidence.json for Gates 1-4
   752	    load_gate_evidence(round_id, report)
   753	    if report.blockers:
   754	        report.blocker(f"close refused: {len(report.blockers)} blocker(s) present")
   755	        return report
   756	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   757	    lock = json.loads(lock_path.read_text())
   758	    if lock.get("status") != "active":
   759	        report.blocker(f"close refused: lock status is '{lock.get('status')}', must be 'active'")
   760	        return report
   761	    lock["status"] = "closed"
   762	    lock["closed_at"] = datetime.now(timezone.utc).isoformat()
   763	    lock_path.write_text(json.dumps(lock, indent=2) + "\n")
   764	    report.ok(f"lock {round_id} transitioned to closed at {lock['closed_at']}")
   765	    return report

   459	def read_pointer_file(p: Path) -> tuple[str, str] | None:
   460	    """Read `lint_config.txt` or `convention_version.txt` — expects `<path>\\n<sha256:...>`."""
   461	    if not p.exists():
   462	        return None
   463	    lines = [ln.strip() for ln in p.read_text().splitlines() if ln.strip() and not ln.strip().startswith("#")]
   464	    if len(lines) < 2:
   465	        return None
   466	    return lines[0], lines[1]

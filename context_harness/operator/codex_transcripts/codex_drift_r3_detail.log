   517	
   518	def _match_glob(rel: str, pattern: str) -> bool:
   519	    """Glob matcher with strict POSIX-style semantics:
   520	      * = [^/]*    (does NOT cross directory separators)
   521	      ** = .*      (crosses directories; must be a full segment — we normalize `**/` and `/**`)
   522	      ? = [^/]
   523	    Exact match short-circuits. Implementation: escape pattern → substitute glob tokens → regex match.
   524	    """
   525	    if pattern == rel:
   526	        return True
   527	    # Escape pattern then substitute glob tokens back in.
   528	    escaped = re.escape(pattern)
   529	    # Order matters: `**/` and `/**` must be handled before `**` and `*`.
   530	    escaped = escaped.replace(r"\*\*/", "(?:.*/)?")
   531	    escaped = escaped.replace(r"/\*\*", "(?:/.*)?")
   532	    escaped = escaped.replace(r"\*\*", ".*")
   533	    escaped = escaped.replace(r"\*", "[^/]*")
   534	    escaped = escaped.replace(r"\?", "[^/]")
   535	    return re.match("^" + escaped + "$", rel) is not None
   536	
   537	
   538	def _matches_any(rel: str, patterns) -> bool:
   539	    for pat in patterns:
   540	        if _match_glob(rel, pat):
   541	            return True
   542	    return False

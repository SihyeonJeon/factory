+    enum Color { ... }
+    enum Font { ... }
+    enum Radius { ... }
+    enum Spacing { ... }
+    enum Sheet { ... }
+}
+```
+
+Required members:
+
+- `UnfadingTheme.Color.coral` = `#F5998C`
+- `UnfadingTheme.Color.primary` aliases or maps to coral
+- `UnfadingTheme.Color.lavender` = `#C2B0DE`
+- `UnfadingTheme.Color.cream` = `#FFFAF5`

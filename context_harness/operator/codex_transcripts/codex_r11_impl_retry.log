+                        .foregroundStyle(UnfadingTheme.Color.textOnPrimary)
+                        .padding(.horizontal, UnfadingTheme.Spacing.sm)
+                        .padding(.vertical, UnfadingTheme.Spacing.xs)
+                        .background(UnfadingTheme.Color.primary, in: Capsule())
+                }
+            }

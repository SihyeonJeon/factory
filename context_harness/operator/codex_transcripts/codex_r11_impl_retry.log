+            }
+        }
+        .padding(UnfadingTheme.Spacing.lg)
+        .unfadingCardBackground(fill: UnfadingTheme.Color.sheet, radius: UnfadingTheme.Radius.card)
+    }
+}
+
+private struct PremiumTier: Identifiable {
+    let id = UUID()
+    let name: String
+    let price: String
+    let badge: String?
+    let features: [String]
+}

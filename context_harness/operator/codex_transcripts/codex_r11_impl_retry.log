+                    Button(UnfadingLocalized.Settings.premiumComingSoon) {
+                    }
+                    .buttonStyle(.unfadingPrimaryFullWidth)
+                    .disabled(true)
+                }
+                .padding(UnfadingTheme.Spacing.xl)
+            }

   203	def check_file_index_coverage(cfg: dict, report: CheckReport) -> None:
   204	    coverage = cfg.get("file_index_coverage", {})
   205	    if not coverage:
   206	        return
   207	    target = REPO / coverage["target"]
   208	    if not target.exists():
   209	        report.blocker(f"FILE_INDEX target missing: {coverage['target']}")
   210	        return
   211	    index_text = target.read_text()
   212	    exempt_globs = coverage.get("exempt", [])
   213	    candidates: list[Path] = []
   214	    for pattern in coverage.get("required_scan_globs", []):
   215	        candidates.extend(REPO.glob(pattern))
   216	
   217	    missing: list[str] = []
   218	    for p in sorted(set(candidates)):
   219	        rel = p.relative_to(REPO).as_posix()
   220	        if _match_glob_exempt(rel, exempt_globs):
   221	            continue
   222	        if rel in index_text or p.name in index_text:
   223	            continue
   224	        missing.append(rel)
   225	    if missing:
   226	        for m in missing:
   227	            report.blocker(f"FILE_INDEX missing entry for: {m}")
   228	    else:
   229	        report.ok("FILE_INDEX coverage complete")

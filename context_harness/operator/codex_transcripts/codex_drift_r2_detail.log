   331	def check_legacy_superseded_headers(cfg: dict, report: CheckReport) -> None:
   332	    for rel in cfg.get("superseded_docs", []):
   333	        p = REPO / rel
   334	        if not p.exists():
   335	            report.advisory(f"superseded doc missing on disk: {rel}")
   336	            continue
   337	        head = "\n".join(p.read_text().splitlines()[:10])
   338	        if "SUPERSEDED" not in head and "ACTIVE" not in head:
   339	            report.blocker(f"legacy doc {rel} lacks SUPERSEDED/ACTIVE marker in first 10 lines")
   340	        elif "SUPERSEDED" in head:
   341	            report.ok(f"legacy doc marked SUPERSEDED: {rel}")
   342	        else:
   343	            report.advisory(f"legacy doc marked ACTIVE: {rel} — verify intentional")

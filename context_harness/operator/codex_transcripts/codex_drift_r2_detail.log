   466	def cmd_lock(round_id: str) -> CheckReport:
   467	    report = CheckReport()
   468	    round_dir = CONTRACTS_DIR / round_id
   469	    if not round_dir.exists():
   470	        report.blocker(f"contract directory missing: {round_dir}")
   471	        return report
   472	    hashes: dict[str, str] = {}
   473	    for f in REQUIRED_CONTRACT_FILES:
   474	        p = round_dir / f
   475	        if not p.exists():
   476	            report.blocker(f"contract file missing: {round_id}/{f}")
   477	            continue
   478	        hashes[f] = sha256_file(p)
   479	        report.ok(f"hashed {round_id}/{f}")
   480	    if report.blockers:
   481	        return report
   482	    LOCKS_DIR.mkdir(parents=True, exist_ok=True)
   483	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   484	    if lock_path.exists():
   485	        report.blocker(f"lock already exists: {lock_path}")
   486	        return report
   487	    # base_commit for commit traceability (item 11)
   488	    try:
   489	        base_commit = subprocess.check_output(
   490	            ["git", "rev-parse", "HEAD"], cwd=REPO, text=True
   491	        ).strip()
   492	    except Exception:
   493	        base_commit = None
   494	    lock = {
   495	        "round_id": round_id,
   496	        "schema_version": 1,
   497	        "started_at": datetime.now(timezone.utc).isoformat(),
   498	        "status": "active",
   499	        "operators": {
   500	            "claude_code": {"session": "this-session", "role_default": "implementer"},
   501	            "codex": {"session": "", "role_default": "designer_reviewer"},
   502	        },
   503	        "base_commit": base_commit,
   504	        "hashes": hashes,
   505	        "amendments": [],
   506	        "stages_completed": [],
   507	        "closed_at": None,
   508	    }
   509	    lock_path.write_text(json.dumps(lock, indent=2) + "\n")
   510	    report.ok(f"lock created: {lock_path} (base_commit={base_commit or 'unknown'})")
   511	    report.ok("ready")
   512	    return report
   513	
   514	
   515	def check_commit_traceability(lock: dict, report: CheckReport) -> None:
   516	    """Item 11: commits since lock base_commit must touch only whitelisted files."""
   517	    base = lock.get("base_commit")
   518	    round_dir = CONTRACTS_DIR / lock["round_id"]
   519	    wl_path = round_dir / "file_whitelist.txt"
   520	    if not base:
   521	        report.advisory("lock has no base_commit — commit traceability cannot be verified (legacy lock)")
   522	        return
   523	    if not wl_path.exists():
   524	        report.blocker("file_whitelist.txt missing — cannot verify commit traceability")
   525	        return
   526	    # Effective whitelist = base + amendments
   527	    whitelist: set[str] = set()
   528	    for ln in wl_path.read_text().splitlines():
   529	        ln = ln.strip()
   530	        if ln and not ln.startswith("#"):
   531	            whitelist.add(ln)
   532	    for amend in lock.get("amendments", []):
   533	        apath = round_dir / amend.get("file", "")
   534	        if apath.exists() and apath.name.startswith("file_whitelist.amendment."):
   535	            for ln in apath.read_text().splitlines():
   536	                ln = ln.strip()
   537	                if ln.startswith("+"):
   538	                    whitelist.add(ln[1:].strip())
   539	                elif ln.startswith("-"):
   540	                    whitelist.discard(ln[1:].strip())
   541	    try:
   542	        diff_files = subprocess.check_output(
   543	            ["git", "diff", "--name-only", f"{base}..HEAD"], cwd=REPO, text=True
   544	        ).strip().splitlines()
   545	    except Exception as e:
   546	        report.advisory(f"git diff unavailable: {e}")
   547	        return
   548	    out_of_scope: list[str] = []
   549	
   550	    def _matches_whitelist(rel: str) -> bool:
   551	        for pat in whitelist:
   552	            if pat.endswith("/**") and rel.startswith(pat[:-3]):
   553	                return True
   554	            if pat.endswith("/*") and rel.startswith(pat[:-2]) and "/" not in rel[len(pat) - 2:]:
   555	                return True
   556	            if pat == rel:
   557	                return True
   558	        return False
   559	
   560	    for f in diff_files:
   561	        if not f:
   562	            continue
   563	        if not _matches_whitelist(f):
   564	            out_of_scope.append(f)
   565	    if out_of_scope:
   566	        for f in out_of_scope:
   567	            report.blocker(f"commit touches out-of-whitelist path: {f}")
   568	    else:
   569	        report.ok(f"commit traceability ok ({len(diff_files)} files vs whitelist)")
   570	
   571	
   572	def check_live_pointer_hashes(lock: dict, report: CheckReport) -> None:
   573	    """Item 5: lint_config.txt / convention_version.txt hold `<path>\\n<sha>`. Recompute and compare."""
   574	    round_dir = CONTRACTS_DIR / lock["round_id"]
   575	    for name in ("lint_config.txt", "convention_version.txt"):
   576	        p = round_dir / name
   577	        entry = read_pointer_file(p)
   578	        if entry is None:
   579	            report.advisory(f"{name} does not follow `<path>\\n<sha256:...>` format — live hash check skipped")
   580	            continue
   581	        target_rel, expected = entry
   582	        target = REPO / target_rel
   583	        if not target.exists():
   584	            report.blocker(f"{name} points at missing target: {target_rel}")
   585	            continue
   586	        actual = sha256_file(target)
   587	        if actual != expected:
   588	            report.blocker(f"{name} target {target_rel} live SHA differs from locked SHA")
   589	        else:
   590	            report.ok(f"{name} live hash matches locked target")
   591	
   592	
   593	def cmd_gates(round_id: str) -> CheckReport:
   594	    report = CheckReport()
   595	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   596	    if not lock_path.exists():
   597	        report.blocker(f"lock missing: {lock_path}")
   598	        return report
   599	    try:
   600	        lock = json.loads(lock_path.read_text())
   601	    except json.JSONDecodeError as e:
   602	        report.blocker(f"lock JSON invalid: {e}")
   603	        return report
   604	    round_dir = CONTRACTS_DIR / round_id
   605	    # Contract immutability
   606	    for fname, expected in lock.get("hashes", {}).items():
   607	        p = round_dir / fname
   608	        if not p.exists():
   609	            report.blocker(f"contract file missing (hashed at lock): {fname}")
   610	            continue
   611	        actual = sha256_file(p)
   612	        if actual != expected:
   613	            report.blocker(f"contract file MUTATED after lock: {fname} expected {expected[:20]} got {actual[:20]}")
   614	        else:
   615	            report.ok(f"contract file immutable: {fname}")
   616	    # Live pointer hashes (lint/convention)
   617	    check_live_pointer_hashes(lock, report)
   618	    # Commit traceability
   619	    check_commit_traceability(lock, report)
   620	    # Lint + audit
   621	    lint_report = cmd_lint()
   622	    audit_report = cmd_audit_operator_layer()
   623	    report.merge(lint_report)
   624	    report.merge(audit_report)
   625	    return report
   626	
   627	
   628	def cmd_close(round_id: str) -> CheckReport:
   629	    report = cmd_gates(round_id)
   630	    if report.blockers:
   631	        report.blocker(f"close refused: {len(report.blockers)} gate blocker(s) present")
   632	        return report
   633	    lock_path = LOCKS_DIR / f"{round_id}.lock"
   634	    lock = json.loads(lock_path.read_text())
   635	    if lock.get("status") != "active":
   636	        report.blocker(f"close refused: lock status is '{lock.get('status')}', must be 'active'")
   637	        return report
   638	    lock["status"] = "closed"
   639	    lock["closed_at"] = datetime.now(timezone.utc).isoformat()
   640	    lock_path.write_text(json.dumps(lock, indent=2) + "\n")
   641	    report.ok(f"lock {round_id} transitioned to closed at {lock['closed_at']}")
   642	    return report

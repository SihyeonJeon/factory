   291	    report = CheckReport()
   292	    check_line_caps(cfg, report)
   293	    check_loader_pointers(cfg, report)
   294	    check_file_index_coverage(cfg, report)
   295	    check_meeting_frontmatter(cfg, report)
   296	    return report

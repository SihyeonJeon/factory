   159	def check_line_caps(cfg: dict, report: CheckReport) -> None:
   160	    caps = cfg.get("line_caps", {})
   161	    warnings = cfg.get("line_warnings", {})
   162	    for rel, cap in caps.items():
   163	        p = REPO / rel
   164	        if not p.exists():
   165	            report.blocker(f"line-cap target missing: {rel}")
   166	            continue
   167	        n = line_count(p)
   168	        if n > cap:
   169	            report.blocker(f"line cap exceeded: {rel} = {n} lines (cap {cap})")
   170	        else:
   171	            report.ok(f"line cap: {rel} = {n}/{cap}")
   172	    for rel, warn in warnings.items():
   173	        p = REPO / rel
   174	        if p.exists():
   175	            n = line_count(p)
   176	            if n >= warn:
   177	                report.advisory(f"line warning: {rel} = {n} (warn ≥ {warn})")
   178	

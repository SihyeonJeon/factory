   180	def check_loader_pointers(cfg: dict, report: CheckReport) -> None:
   181	    for entry in cfg.get("loader_pointers", []):
   182	        f = REPO / entry["file"]
   183	        must = entry["must_reference"]
   184	        if not f.exists():
   185	            report.blocker(f"loader missing: {entry['file']}")
   186	            continue
   187	        if must not in f.read_text():
   188	            report.blocker(f"loader {entry['file']} does not reference {must}")
   189	        else:
   190	            report.ok(f"loader references target: {entry['file']} → {must}")
   191	
   192	
   193	def _match_glob_exempt(rel_path: str, exempt_globs: list[str]) -> bool:
   194	    for g in exempt_globs:
   195	        if g.endswith("/**"):
   196	            if rel_path.startswith(g[:-3]):
   197	                return True
   198	        elif rel_path == g:
   199	            return True
   200	    return False

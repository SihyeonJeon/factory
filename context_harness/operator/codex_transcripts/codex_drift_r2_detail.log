   317	def check_session_resume_freshness(report: CheckReport) -> None:
   318	    if not SESSION_RESUME.exists():
   319	        report.blocker("SESSION_RESUME.md missing")
   320	        return
   321	    mtime = datetime.fromtimestamp(SESSION_RESUME.stat().st_mtime, tz=timezone.utc)
   322	    age_hours = (datetime.now(timezone.utc) - mtime).total_seconds() / 3600
   323	    if age_hours > 168:  # 7 days
   324	        report.blocker(f"SESSION_RESUME.md stale > 7d ({age_hours:.1f}h)")
   325	    elif age_hours > 48:
   326	        report.advisory(f"SESSION_RESUME.md stale > 48h ({age_hours:.1f}h)")
   327	    else:
   328	        report.ok(f"SESSION_RESUME.md fresh ({age_hours:.1f}h)")

   452	    "eval_protocol.md",
   453	]
   454	
   455	
   456	def read_pointer_file(p: Path) -> tuple[str, str] | None:
   457	    """Read `lint_config.txt` or `convention_version.txt` — expects `<path>\\n<sha256:...>`."""
   458	    if not p.exists():
   459	        return None
   460	    lines = [ln.strip() for ln in p.read_text().splitlines() if ln.strip() and not ln.strip().startswith("#")]
   461	    if len(lines) < 2:
   462	        return None
   463	    return lines[0], lines[1]

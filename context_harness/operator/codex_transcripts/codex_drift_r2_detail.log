   346	def audit_operator_layer(report: CheckReport, cfg: dict) -> None:
   347	    # Doc existence
   348	    required_docs = [
   349	        "OPERATOR.md",
   350	        "FILE_INDEX.md",
   351	        "STAGE_CONTRACT.md",
   352	        "MEETING_PROTOCOL.md",
   353	        "REGULATION.md",
   354	        "PROCESS_AUDIT_CHECKLIST.md",
   355	        "CHANGELOG.md",
   356	    ]
   357	    for d in required_docs:
   358	        p = OPERATOR_DIR / d
   359	        if not p.exists():
   360	            report.blocker(f"operator doc missing: {d}")
   361	        else:
   362	            report.ok(f"operator doc present: {d}")
   363	
   364	    # Stage ID consistency
   365	    allowed_stages = set(cfg.get("meeting_frontmatter_allowed", {}).get("stage", []))
   366	    if allowed_stages and STAGE_CONTRACT_DOC.exists():
   367	        sc_text = STAGE_CONTRACT_DOC.read_text()
   368	        missing_in_sc = [s for s in allowed_stages if s not in sc_text]
   369	        if missing_in_sc:
   370	            for s in missing_in_sc:
   371	                report.blocker(f"stage_id '{s}' in lint_config.stage but absent from STAGE_CONTRACT.md")
   372	        else:
   373	            report.ok(f"stage_ids consistent across lint_config + STAGE_CONTRACT.md ({len(allowed_stages)})")
   374	
   375	    # Stage IDs referenced in MEETING_PROTOCOL
   376	    if allowed_stages and MEETING_PROTOCOL_DOC.exists():
   377	        mp_text = MEETING_PROTOCOL_DOC.read_text()
   378	        missing_in_mp = [s for s in allowed_stages if s not in mp_text]
   379	        if missing_in_mp:
   380	            for s in missing_in_mp:
   381	                report.blocker(f"stage_id '{s}' not documented in MEETING_PROTOCOL.md")
   382	        else:
   383	            report.ok("stage_ids all present in MEETING_PROTOCOL.md")
   384	
   385	    # Precedence — REGULATION lists all precedence entries from lint config
   386	    precedence = cfg.get("precedence", [])
   387	    if REGULATION_DOC.exists():
   388	        reg = REGULATION_DOC.read_text()
   389	        if "Precedence Ladder" not in reg:
   390	            report.blocker("REGULATION.md missing Precedence Ladder section")
   391	        else:
   392	            for doc in precedence:
   393	                if isinstance(doc, str) and doc.startswith("context_harness/operator/") and doc not in reg:
   394	                    report.advisory(f"precedence entry '{doc}' not textually present in REGULATION.md")
   395	
   396	    # Referenced file existence — any path-like token inside operator docs that points at a real location should resolve.
   397	    path_like = re.compile(r"(?:`|\()((?:context_harness|docs|harness|workspace|reports|operator)/[a-zA-Z0-9_./-]+)(?:`|\))")
   398	    broken: list[tuple[str, str]] = []
   399	    for doc_path in [OPERATOR_DOC, REGULATION_DOC, STAGE_CONTRACT_DOC, MEETING_PROTOCOL_DOC, FILE_INDEX, OPERATOR_DIR / "PROCESS_AUDIT_CHECKLIST.md"]:
   400	        if not doc_path.exists():
   401	            continue
   402	        doc_is_in_operator = OPERATOR_DIR in doc_path.resolve().parents or doc_path.resolve() == OPERATOR_DIR
   403	        for m in path_like.finditer(doc_path.read_text()):
   404	            rel = m.group(1)
   405	            # Skip placeholders and wildcards
   406	            if "<" in rel or ">" in rel or "**" in rel or "*" in rel or "..." in rel:
   407	                continue
   408	            # Skip known future-path directories referenced with trailing slash
   409	            if rel.endswith("/"):
   410	                continue
   411	            # Try two resolutions: repo-root, and (for bare `operator/...` from inside operator docs) context_harness/
   412	            candidates = [REPO / rel]
   413	            if rel.startswith("operator/") and doc_is_in_operator:
   414	                candidates.append(REPO / "context_harness" / rel)
   415	            if any(c.exists() for c in candidates):
   416	                continue
   417	            broken.append((doc_path.name, rel))
   418	    if broken:
   419	        seen = set()
   420	        for doc_name, rel in broken:
   421	            key = (doc_name, rel)
   422	            if key in seen:
   423	                continue
   424	            seen.add(key)
   425	            report.advisory(f"operator doc {doc_name} points at missing path: {rel}")
   426	
   427	    # SESSION_RESUME freshness
   428	    check_session_resume_freshness(report)
   429	
   430	    # Legacy SUPERSEDED headers
   431	    check_legacy_superseded_headers(cfg, report)
   432	

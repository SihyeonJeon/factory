   232	def check_meeting_frontmatter(cfg: dict, report: CheckReport) -> None:
   233	    meetings_dir = OPERATOR_DIR / "meetings"
   234	    if not meetings_dir.exists():
   235	        return
   236	    required = cfg.get("meeting_required_frontmatter", [])
   237	    allowed = cfg.get("meeting_frontmatter_allowed", {})
   238	    decided_sections = cfg.get("meeting_required_sections", {}).get("decided", [])
   239	    challenge = cfg.get("challenge_section", {})
   240	    factual_stages = set(challenge.get("factual_stages", []))
   241	    factual_phrase = challenge.get("factual_required_phrase", "")
   242	    decision_keywords = challenge.get("decision_required_keywords", [])
   243	
   244	    for mp in sorted(meetings_dir.glob("*.md")):
   245	        if mp.name.startswith("_"):
   246	            continue
   247	        text = mp.read_text()
   248	        fm_match = re.match(r"^---\n(.*?)\n---\n", text, re.DOTALL)
   249	        if not fm_match:
   250	            report.blocker(f"meeting missing frontmatter: {mp.name}")
   251	            continue
   252	        try:
   253	            fm = parse_simple_frontmatter(fm_match.group(1))
   254	        except Exception as e:
   255	            report.blocker(f"meeting frontmatter invalid ({mp.name}): {e}")
   256	            continue
   257	        for k in required:
   258	            if k not in fm:
   259	                report.blocker(f"meeting {mp.name} missing frontmatter key: {k}")
   260	        for k, vals in allowed.items():
   261	            v = fm.get(k)
   262	            if v is not None and v not in vals:
   263	                report.blocker(f"meeting {mp.name} frontmatter {k}={v} not in allowed")
   264	        status = fm.get("status")
   265	        stage = fm.get("stage")
   266	        if status == "decided":
   267	            for sec in decided_sections:
   268	                if sec not in text:
   269	                    report.blocker(f"meeting {mp.name} status=decided missing: {sec}")
   270	            cs_match = re.search(r"## Challenge Section\s*(.*?)(?=\n## |\Z)", text, re.DOTALL)
   271	            cs_body = cs_match.group(1) if cs_match else ""
   272	            if stage in factual_stages:
   273	                if factual_phrase not in cs_body:
   274	                    report.blocker(f"meeting {mp.name} (factual) Challenge missing required phrase")
   275	                else:
   276	                    # Require Evidence: section with ≥1 path/command reference
   277	                    ev_match = FACTUAL_EVIDENCE_PATTERN.search(cs_body)
   278	                    if not ev_match:
   279	                        report.blocker(f"meeting {mp.name} (factual) missing Evidence: section with bullet list")
   280	                    else:
   281	                        bullets = ev_match.group(1)
   282	                        if not EVIDENCE_REF_PATTERN.search(bullets):
   283	                            report.blocker(f"meeting {mp.name} (factual) Evidence bullets lack any path/command/hash reference")
   284	            else:
   285	                if stage in NORMATIVE_STAGES and not any(kw.lower() in cs_body.lower() for kw in decision_keywords):
   286	                    report.blocker(f"meeting {mp.name} Challenge Section lacks any of: {decision_keywords}")
   287	

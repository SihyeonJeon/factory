   304	def parse_stage_ids_from_stage_contract() -> set[str]:
   305	    """Extract `stage_id` values from the stage matrix table in STAGE_CONTRACT.md."""
   306	    if not STAGE_CONTRACT_DOC.exists():
   307	        return set()
   308	    text = STAGE_CONTRACT_DOC.read_text()
   309	    ids: set[str] = set()
   310	    # backtick-quoted snake_case ids in table rows
   311	    for m in re.finditer(r"`([a-z][a-z0-9_]+)`", text):
   312	        ids.add(m.group(1))
   313	    # Filter by ones that look like stage_ids — cross-check with known set at call site.
   314	    return ids

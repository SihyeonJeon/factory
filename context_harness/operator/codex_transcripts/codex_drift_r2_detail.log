   123	def parse_simple_frontmatter(block: str) -> dict:
   124	    """Minimal YAML-subset parser for meeting frontmatter.
   125	    Supports: `key: value`, `key: [a, b, c]`. No multiline or anchors.
   126	    """
   127	    out: dict = {}
   128	    for raw in block.splitlines():
   129	        line = raw.rstrip()
   130	        if not line or line.lstrip().startswith("#"):
   131	            continue
   132	        if ":" not in line:
   133	            continue
   134	        key, _, value = line.partition(":")
   135	        key = key.strip()
   136	        value = value.strip()
   137	        if value.startswith(("\"", "'")) and value.endswith(value[0]):
   138	            value = value[1:-1]
   139	        if value.startswith("[") and value.endswith("]"):
   140	            inner = value[1:-1].strip()
   141	            items = [x.strip().strip("\"'") for x in inner.split(",")] if inner else []
   142	            out[key] = items
   143	        else:
   144	            out[key] = value
   145	    return out
   146	
   147	
   148	def line_count(p: Path) -> int:
   149	    if not p.exists():
   150	        return 0
   151	    return len(p.read_text().splitlines())
